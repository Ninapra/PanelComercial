# =============================================================================
# api/.env.example — Plantilla de variables de entorno para el backend Flask
# =============================================================================
# Copia este archivo a `api/.env` y completa los valores reales.
# `api/.env` está en .gitignore y NUNCA debe commitearse.
# =============================================================================


# -----------------------------------------------------------------------------
# Flask
# -----------------------------------------------------------------------------
# Clave para firmar sesiones y cookies. Generar una nueva con:
#   python -c "import secrets; print(secrets.token_hex(32))"
# NO reusar entre entornos (dev / staging / prod).
SECRET_KEY=change-me-generate-a-unique-value-for-production


# -----------------------------------------------------------------------------
# Admin inicial (solo se usa en el primer arranque si la BD está vacía)
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-use-strong-password
# Nombre para mostrar del admin (también se usa para derivar la inicial)
ADMIN_NAME=Administrador

# -----------------------------------------------------------------------------
# Usuarios adicionales (agentes/operadores)
# -----------------------------------------------------------------------------
# JSON con array de usuarios extras que se crean al primer arranque si no
# existen. El hash de password se aplica con werkzeug (no se almacena plano).
# Formato ejemplo (una sola línea en .env):
# USERS_SEED_JSON=[{"email":"paula@example.com","password":"change-me","nombre":"Paula","rol":"agente"}]
USERS_SEED_JSON=


# -----------------------------------------------------------------------------
# SMTP / IMAP — para envío de notificaciones y copia en Enviados
# -----------------------------------------------------------------------------
IMAP_USER=your-email@example.com
IMAP_PASSWORD=your-imap-password-here
IMAP_HOST=imap.example.com
IMAP_PORT=993

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_CIPHER=ssl
SMTP_SENDER=Renovaciones <your-email@example.com>
SMTP_DESTINATION=your-email@example.com
SMTP_MAX_PER_DAY=300


# -----------------------------------------------------------------------------
# Reporte diario — destinatario del resumen de envíos
# -----------------------------------------------------------------------------
REPORT_RECIPIENT=reports@example.com


# -----------------------------------------------------------------------------
# Integraciones externas
# -----------------------------------------------------------------------------
# Anthropic Claude API (usado para mejorar plantillas de correo)
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here


# -----------------------------------------------------------------------------
# CORS — orígenes permitidos para llamadas cross-origin desde el frontend
# -----------------------------------------------------------------------------
# Coma-separado. Solo las rutas bajo /api/* aceptan CORS.
# En producción lista los dominios reales (ej. https://panel.example.com).
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173

# =============================================================================
# web/.env.example — Variables expuestas al bundle del frontend (Vite)
# =============================================================================
# Solo las variables con prefijo VITE_ se incluyen en el bundle.
# NUNCA pongas aquí secretos server-side (API keys de Anthropic, etc.) — esos
# quedan en api/.env y solo se acceden desde el backend Flask.
# =============================================================================

VITE_API_BASE_URL=http://127.0.0.1:5000
# Alias no-VITE para el cliente legacy (window.__API_BASE__ en config/api-client.js)
# API_BASE=http://127.0.0.1:5000
VITE_ENV=development
VITE_AUTH_STORAGE_KEY=pc_session

# Telemetría / feature flags (opcional)
# VITE_SENTRY_DSN=https://your-dsn-example.ingest.sentry.io/0
# VITE_FEATURE_NEW_DASHBOARD=false
